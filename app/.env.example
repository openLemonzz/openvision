# ============================================
# VISION - Supabase Configuration
# ============================================

# Get these values from your Supabase project:
# - Project URL: Dashboard > Connect or Project Settings > API
# - Browser key: Dashboard > Connect or Project Settings > API > anon/publishable key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Note: Copy this file to .env and fill in your actual Supabase credentials.
# For local email confirmation flows, also set Authentication > URL Configuration > Site URL
# to http://localhost:5173 and add http://localhost:5173 to Redirect URLs.
# Do NOT commit .env to version control.
