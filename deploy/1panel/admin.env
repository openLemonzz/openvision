# ============================================
# VISION Admin 后端 - 生产环境配置
# ============================================

# Supabase 项目配置（从 Supabase Dashboard > Project Settings > API 获取）
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_API_BASE_URL=/api

# Admin 服务端口（容器内端口，一般不改）
PORT=9902

# Web 前端线上域名（用于 CORS，填写你给用户访问的域名）
WEB_ORIGIN=https://your-web-domain.com

# Supabase 数据库直连地址（用于后端业务数据存储）
# 从 Supabase Dashboard > Connect > Nodejs > "Transaction pooler" 或 "Session pooler" 获取
DATABASE_URL=postgresql://postgres.xxxxx:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Supabase 项目地址
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key（⚠️ 绝不要暴露到前端，仅后端使用）
# Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# 配置加密密钥（⚠️ 部署前必须更换为强随机字符串）
# 可用命令生成：openssl rand -hex 32
CONFIG_CRYPT_KEY=change-me-to-64-char-random-hex-string
