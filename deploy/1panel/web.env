# ============================================
# VISION Web 前端 - 生产环境配置
# ============================================

# Supabase 项目配置（从 Supabase Dashboard > Project Settings > API 获取）
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Admin API 地址（线上域名，末尾带 /api）
# 示例：如果你的 admin 域名是 https://admin.vision.app，则填 https://admin.vision.app/api
VITE_ADMIN_API_URL=https://your-admin-domain.com/api

# Admin 应用地址（线上域名，不带路径）
VITE_ADMIN_APP_URL=https://your-admin-domain.com
